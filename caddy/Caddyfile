# Production Caddyfile — HTTP-01 challenge, без wildcard.
#
# Домен siteadaptor.de обслуживается в Hostinger (NS dns-parking.com), где нет
# Caddy DNS-плагина → wildcard через DNS-01 недоступен. Поэтому сертификаты
# выпускаются по HTTP-01: главный домен — явно, субдомены арендаторов — через
# on-demand TLS (сертификат на каждый субдомен при первом обращении).
#
# Требуется только: A-записи (@ и *) на IP сервера + открытые порты 80/443.
# Ни DNS-API-токена, ни смены провайдера не нужно.
#
# `web` — имя сервиса из docker-compose.prod.yml (Django/gunicorn на :8000).
#
# ⚠️ Лимит Let's Encrypt: ~50 сертификатов/неделя на домен. Для dev и десятков
# арендаторов хватает с запасом. Для боевого масштаба — перейти на wildcard
# через Cloudflare DNS (сменить NS + плагин caddy-dns/cloudflare).

{
	email admin@siteadaptor.de
	# Авторизация субдоменов для on-demand TLS: Caddy спрашивает Django,
	# можно ли выпускать сертификат для запрошенного хоста. Endpoint уже
	# реализован (apps/core/health.verify_domain): разрешает siteadaptor.de,
	# *.siteadaptor.de и любые домены из модели Domain.
	on_demand_tls {
		# Запрос идёт с Host: siteadaptor.de (через сетевой алиас web-контейнера),
		# т.к. этот хост резолвится в public-схему и verify_domain отвечает 200.
		# Прямой http://web:8000 слал бы Host: web → 404 (нет такого арендатора).
		ask http://siteadaptor.de:8000/internal/verify-domain
	}
}

# Главный домен — сертификат по HTTP-01 автоматически.
siteadaptor.de {
	encode zstd gzip
	reverse_proxy web:8000
}

# Субдомены арендаторов ({slug}.siteadaptor.de) и будущие custom-домены —
# сертификат выпускается on-demand при первом запросе (с проверкой через ask).
https:// {
	encode zstd gzip
	tls {
		on_demand
	}
	reverse_proxy web:8000
}
