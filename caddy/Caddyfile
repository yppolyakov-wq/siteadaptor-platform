# Production Caddyfile.
#
# Wildcard TLS для всех субдоменов арендаторов (*.siteadaptor.de) выпускается
# через DNS-01 challenge — поэтому нужен DNS-плагин (см. caddy/Dockerfile) и токен
# DNS-провайдера в .env.prod (HETZNER_DNS_API_TOKEN).
#
# `web` — имя сервиса из docker-compose.prod.yml (Django/gunicorn на :8000).

{
	email admin@siteadaptor.de
}

siteadaptor.de, *.siteadaptor.de {
	encode zstd gzip
	tls {
		dns hetzner {env.HETZNER_DNS_API_TOKEN}
	}
	reverse_proxy web:8000
}

