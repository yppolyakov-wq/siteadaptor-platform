# Production Caddyfile (placeholder; будет уточнён в Sprint 6 / deploy).
#
# Wildcard для subdomain + custom domains через on-demand TLS.

*.platform.com, platform.com {
    reverse_proxy web:8000
}

{
    on_demand_tls {
        ask https://platform.com/api/verify-domain
    }
}

:443 {
    tls {
        on_demand
    }
    reverse_proxy web:8000
}
