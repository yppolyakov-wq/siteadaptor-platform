SECRET_KEY=change-me-to-something-secret-and-long
DEBUG=True
# Префикс "." разрешает все поддомены: .siteadaptor.de = siteadaptor.de + *.siteadaptor.de
ALLOWED_HOSTS=siteadaptor.de,.siteadaptor.de,localhost,127.0.0.1

# Database
DB_NAME=platform
DB_USER=platform
DB_PASSWORD=platform
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
# /0 — Celery broker, /1 — Django cache + сессии, /2 — Celery result backend
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_RESULT_URL=redis://localhost:6379/2

# Persistent DB connections (см. CONN_MAX_AGE в settings/base.py)
DB_CONN_MAX_AGE=60

# Email (dev: console backend; prod: Resend)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@platform.local

# Stripe (test keys)
STRIPE_LIVE_MODE=False
STRIPE_TEST_PUBLIC_KEY=
STRIPE_TEST_SECRET_KEY=
DJSTRIPE_WEBHOOK_SECRET=

# S3 (Hetzner Object Storage) — пусто в dev, FileSystemStorage используется
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=platform-media
AWS_S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
AWS_S3_REGION_NAME=nbg1

# Sentry (prod)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
