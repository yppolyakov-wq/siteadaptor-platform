# --- Production env (app-сервер). Скопируй в .env.prod и заполни. ---
# НИКОГДА не коммить .env.prod — он в .gitignore.

# Django
SECRET_KEY=CHANGE-ME-long-random-secret
DEBUG=False
ALLOWED_HOSTS=siteadaptor.de,.siteadaptor.de

# Database
# Режим SINGLE (один сервер, Postgres в Docker): DB_HOST=db
# Режим PROD (отдельный db-сервер CCX13):        DB_HOST=<приватный IP db-сервера>
DB_NAME=platform
DB_USER=platform
DB_PASSWORD=CHANGE-ME-strong-db-password
DB_HOST=db               # single: "db"; прод: приватный IP db-сервера (напр. 10.0.0.2)
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (локально на app-сервере, сервис redis из compose)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_RESULT_URL=redis://redis:6379/2

# Caddy TLS: используется HTTP-01 challenge (см. caddy/Caddyfile) — НИЧЕГО
# задавать не нужно, только A-записи (@ и *) на IP сервера + порты 80/443.
# Эта переменная нужна ТОЛЬКО если перейдёшь на wildcard через DNS-01.
# HETZNER_DNS_API_TOKEN=

# Email (Resend)
RESEND_API_KEY=CHANGE-ME
DEFAULT_FROM_EMAIL=noreply@siteadaptor.de

# Stripe (live keys на проде)
STRIPE_LIVE_MODE=True
STRIPE_TEST_PUBLIC_KEY=
STRIPE_TEST_SECRET_KEY=
DJSTRIPE_WEBHOOK_SECRET=CHANGE-ME

# S3 (Hetzner Object Storage)
AWS_ACCESS_KEY_ID=CHANGE-ME
AWS_SECRET_ACCESS_KEY=CHANGE-ME
AWS_STORAGE_BUCKET_NAME=platform-media
AWS_S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
AWS_S3_REGION_NAME=nbg1

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
